# 复制为 config.yaml 后按需修改（项目仅使用 YAML 配置，无 .env）

app:
  name: "West Pacific Petrochemical"
  debug: false

server:
  host: "0.0.0.0"
  port: 8866

database:
  host: "localhost"
  port: 5432
  user: "postgres"
  password: "123456"
  name: "west-pacific"

redis:
  url: "redis://localhost:6379/0"

vector_store:
  type: "chroma"
  url: ""

storage:
  minio_endpoint: "localhost:9000"
  minio_access_key: ""
  minio_secret_key: ""
  minio_bucket: "default"

# 生产环境务必改为随机长字符串，且不少于 32 字符（避免 InsecureKeyLengthWarning）
jwt:
  secret_key: "change-me-in-production-min-32-chars"
  algorithm: "HS256"
  access_token_expire_minutes: 60
